# ---- Server ----
NODE_ENV=development
PORT=8787

# ---- Postgres (Neon in prod, local docker-compose in dev) ----
DATABASE_URL=postgres://thinkcashback:thinkcashback@localhost:5432/thinkcashback

# ---- Redis (Upstash in prod, local docker-compose in dev) ----
# Leave empty to use the in-memory fallback (single-process only).
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Used to sign session JWTs issued after GitHub OAuth.
JWT_SECRET=dev-only-change-me

# Master key for envelope-encrypting the developer signing secret at rest
# (AES-256-GCM; see packages/server/src/lib/secrets.ts). Leave empty in dev to
# store the secret as plaintext; REQUIRED (strong, non-default) in production.
# Generate with:  openssl rand -hex 32
SECRET_ENC_KEY=

# GitHub OAuth app credentials.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8787/api/v1/auth/github/callback

# ---- Economics ----
# Default revenue share for developers, in basis points (8000 = 80%).
DEFAULT_REV_SHARE_BPS=8000

# ---- Anti-fraud ----
# Impression dedup window in milliseconds.
IMPRESSION_DEDUP_WINDOW_MS=5000

# ---- Stripe billing + Connect payouts ----
# Leave STRIPE_SECRET_KEY empty to use the deterministic in-memory fake gateway
# (no network); set a sk_test_... key to talk to Stripe test mode.
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
# Endpoint signing secret (whsec_...) for verifying inbound webhooks.
STRIPE_WEBHOOK_SECRET=
# Settlement currency for top-ups and payouts.
STRIPE_CURRENCY=usd
# Base URL used to build Connect onboarding return/refresh links.
PUBLIC_BASE_URL=http://localhost:8787
# Minimum developer balance (cents) required to request a payout ($10.00).
PAYOUT_MIN_CENTS=1000
