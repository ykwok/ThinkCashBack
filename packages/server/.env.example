# Server-local copy of the root .env.example. See the repository root
# .env.example for the full annotated list of variables.
NODE_ENV=development
PORT=8787
DATABASE_URL=postgres://thinkcashback:thinkcashback@localhost:5432/thinkcashback
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-only-change-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8787/api/v1/auth/github/callback
DEFAULT_REV_SHARE_BPS=8000
IMPRESSION_DEDUP_WINDOW_MS=5000
# Stripe billing + Connect payouts. Empty STRIPE_SECRET_KEY => in-memory fake gateway.
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
PUBLIC_BASE_URL=http://localhost:8787
PAYOUT_MIN_CENTS=1000
